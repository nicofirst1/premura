{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GraderVerdict",
  "description": "Deterministic output of premura.harness.grader.grade. Byte-identical across runs (NFR-001). Excludes ids/timestamps (D5). All arrays sorted.",
  "type": "object",
  "additionalProperties": false,
  "required": ["passed", "rules"],
  "properties": {
    "passed": {
      "type": "boolean",
      "description": "true iff all three rules pass"
    },
    "rules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["loaded", "runtime_valid", "honest_about_gaps"],
      "properties": {
        "loaded": {
          "type": "object",
          "additionalProperties": false,
          "required": ["passed", "warehouse_rows", "logged_rows_inserted"],
          "properties": {
            "passed": { "type": "boolean" },
            "warehouse_rows": { "type": "integer", "minimum": 0 },
            "logged_rows_inserted": { "type": "integer", "minimum": 0 }
          },
          "description": "passed iff warehouse_rows > 0 and warehouse_rows consistent with logged_rows_inserted (FR-062)"
        },
        "runtime_valid": {
          "type": "object",
          "additionalProperties": false,
          "required": ["passed", "violations"],
          "properties": {
            "passed": { "type": "boolean" },
            "violations": {
              "type": "array",
              "items": { "type": "string" },
              "description": "sorted '<clause>: <detail>' from check_runtime_contract (FR-063)"
            }
          }
        },
        "honest_about_gaps": {
          "type": "object",
          "additionalProperties": false,
          "required": ["passed", "silent_drops"],
          "properties": {
            "passed": { "type": "boolean" },
            "silent_drops": {
              "type": "array",
              "items": { "type": "string" },
              "description": "sorted source-field names that were neither loaded nor declared (FR-064). Empty => honest."
            }
          }
        }
      }
    }
  }
}
